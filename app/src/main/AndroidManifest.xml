<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Package Visibility Queries for AdBlockers and Tampering Apps -->
    <queries>
        <package android:name="org.adaway" />
        <package android:name="org.blokada" />
        <package android:name="org.blokada.alarm" />
        <package android:name="org.blokada.app" />
        <package android:name="org.jak_linux.dns66" />
        <package android:name="com.chelpus.lackypatch" />
        <package android:name="com.dimonvideo.luckypatcher" />
        <package android:name="com.adguard.android" />
        <package android:name="com.adguard.android.contentblocker" />
        <package android:name="celzero.bravedns" />
        <package android:name="com.brave.browser" />
        <package android:name="org.adblockplus.adblockplussbrowser" />
        <package android:name="org.adblockplus.android" />
        <package android:name="cc.madkite.freedom" />
        <package android:name="org.sbtools.gamehack" />
    </queries>

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MyApplication">

        <!-- Google AdMob Application ID -->
        <meta-data
            android:name="com.google.android.gms.ads.APPLICATION_ID"
            android:value="ca-app-pub-6715807412270192~2612781545"/>
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.MyApplication">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>
